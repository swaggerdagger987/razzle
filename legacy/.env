RAZZLE_LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions
RAZZLE_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
RAZZLE_LLM_ELITE_MODEL=nvidia/nemotron-3-super-120b-a12b:free
ENVIRONMENT=development

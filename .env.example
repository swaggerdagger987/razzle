# Razzle Environment Variables
# Copy this to .env for local development. On Render, set these in the dashboard.

# Auth
JWT_SECRET=your-random-hex-string-here

# Encryption (used for BYOK API key storage — falls back to JWT_SECRET if not set)
ENCRYPTION_KEY=your-random-hex-string-here

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_ELITE_YEARLY=price_...
STRIPE_COUPON_RAZZLE=coupon_id_for_20pct_off

# GitHub (for DB download in Render build)
GH_TOKEN=ghp_...

# Application
RAZZLE_BASE_URL=http://localhost:8000
ENVIRONMENT=development

# Elite AI-included mode (optional — only needed for Elite tier LLM proxy)
RAZZLE_LLM_API_KEY=sk-or-v1-...
# RAZZLE_LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# RAZZLE_LLM_MODEL=anthropic/claude-3.5-haiku

# Early Adopter Pricing (optional — set EA_ENABLED=1 to activate)
EA_ENABLED=0
EA_PRO_LIMIT=500
EA_ELITE_LIMIT=200
STRIPE_PRICE_EA_PRO_YEARLY=price_...
STRIPE_PRICE_EA_ELITE_YEARLY=price_...

# Lifetime Deals (optional — set LIFETIME_ENABLED=1 to activate)
LIFETIME_ENABLED=0
LIFETIME_LIMIT=100
STRIPE_PRICE_LIFETIME_PRO=price_...
STRIPE_PRICE_LIFETIME_ELITE=price_...

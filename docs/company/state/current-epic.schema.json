{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Razzle Company OS — current epic",
  "type": "object",
  "required": [
    "big_problem",
    "epic_title",
    "atoms",
    "next_atom_id",
    "epic_status",
    "last_updated"
  ],
  "properties": {
    "big_problem": {
      "type": "string",
      "description": "One sentence — highest-leverage product gap this epic resolves."
    },
    "epic_title": {
      "type": "string",
      "description": "3–5 slice epic name."
    },
    "atoms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^atom-[1-5]$" },
          "title": { "type": "string" },
          "parity_ref": { "type": "string" },
          "depth_ref": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "next", "in_progress", "done", "blocked", "skipped"]
          },
          "merge_commit": {
            "type": ["string", "null"],
            "description": "7-char SHA when done"
          }
        }
      }
    },
    "completed_atom_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_atom_id": {
      "type": ["string", "null"],
      "description": "Which atom to plan/build next; null when epic complete"
    },
    "epic_status": {
      "type": "string",
      "enum": ["active", "complete", "blocked"]
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "last_merge_commit": {
      "type": ["string", "null"]
    }
  }
}

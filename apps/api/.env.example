# Razzle V2 API — environment variables

# --- Required in production ---
JWT_SECRET=replace-with-random-hex-string
ENCRYPTION_KEY=replace-with-random-hex-string
ENVIRONMENT=development                 # development | production
RAZZLE_BASE_URL=http://localhost:3000   # frontend origin, for CORS and Stripe redirects
DEV_PLAN=elite                          # free | pro | elite — local premium testing (optional)

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_YEARLY=price_...

# --- LLM (Situation Room) ---
RAZZLE_LLM_API_KEY=sk-or-v1-...                          # OpenRouter key
RAZZLE_LLM_BASE_URL=https://openrouter.ai/api/v1
RAZZLE_LLM_MODEL=anthropic/claude-3.5-haiku

# --- Observability ---
SENTRY_DSN=
POSTHOG_PROJECT_API_KEY=

# --- Reddit bot (Phase 7) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=razzle:!razzle-bot:v2 (by /u/razzle_lol)
REDDIT_USERNAME=
REDDIT_PASSWORD=
